<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>ArcChat.Protocol</AssemblyName>
    <RootNamespace>ArcChat.Protocol</RootNamespace>
    <UseArcChatUi>false</UseArcChatUi>
    <JsonSerializerIsReflectionEnabledByDefault>false</JsonSerializerIsReflectionEnabledByDefault>
    <NoWarn>$(NoWarn);AD0001;CA1054;CA1056;MA0048;RS0016;RS0036;RS0037;RS0041;SA1009;SA1313</NoWarn>
  </PropertyGroup>

  <Import Project="$(ArcChatRepositoryRoot)build\ArcChat.Lib.props" />
</Project>
