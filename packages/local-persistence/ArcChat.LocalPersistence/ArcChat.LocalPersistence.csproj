<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>ArcChat.LocalPersistence</AssemblyName>
    <RootNamespace>ArcChat.LocalPersistence</RootNamespace>
    <UseArcChatUi>false</UseArcChatUi>
    <InterceptorsPreviewNamespaces>$(InterceptorsPreviewNamespaces);Dapper.AOT</InterceptorsPreviewNamespaces>
    <NoWarn>$(NoWarn);AD0001;CA1031;CA2007;MA0004;MA0048;RS0016;RS0036;RS0037;RS0041;SA1009;SA1313</NoWarn>
  </PropertyGroup>

  <Import Project="$(ArcChatRepositoryRoot)build\ArcChat.Lib.props" />

  <ItemGroup>
    <PackageReference Include="Dapper" />
    <PackageReference Include="Dapper.AOT" />
    <PackageReference Include="dbup-sqlite" />
    <PackageReference Include="Microsoft.Data.Sqlite" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\protocol-net\ArcChat.Protocol\ArcChat.Protocol.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Migrations\*.sql" />
  </ItemGroup>
</Project>
