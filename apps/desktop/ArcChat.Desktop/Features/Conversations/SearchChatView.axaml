<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conversations="using:ArcChat.Desktop.Features.Conversations"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="ArcChat.Desktop.Features.Conversations.SearchChatView"
             x:Name="SearchChatRoot"
             x:DataType="conversations:SearchChatViewModel"
             d:DesignWidth="760"
             d:DesignHeight="520"
             mc:Ignorable="d">
  <Design.DataContext>
    <conversations:SearchChatViewModel />
  </Design.DataContext>

  <Grid Margin="24,0,24,24"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="12"
        Background="{DynamicResource ArcChat.Brush.Surface}">
    <DockPanel Grid.Row="0"
               LastChildFill="True">
      <TextBlock DockPanel.Dock="Right"
                 Text="{Binding StatusMessage}"
                 Opacity="0.7"
                 VerticalAlignment="Center" />
      <TextBlock Text="Search Chat"
                 FontSize="{DynamicResource ArcChat.FontSize.Title}"
                 FontWeight="SemiBold" />
    </DockPanel>

    <DockPanel Grid.Row="1"
               LastChildFill="True">
      <Button DockPanel.Dock="Right"
              Margin="8,0,0,0"
              Content="Search"
              Command="{Binding SearchCommand}" />
      <TextBox PlaceholderText="Search across conversations"
               Text="{Binding Query, Mode=TwoWay}" />
    </DockPanel>

    <ListBox Grid.Row="2"
             ItemsSource="{Binding Results}"
             Background="Transparent"
             BorderThickness="0">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <VirtualizingStackPanel />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate DataType="conversations:SearchChatResult"
                      x:DataType="conversations:SearchChatResult">
          <Border Margin="0,0,0,8"
                  Padding="12"
                  CornerRadius="8"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource ArcChat.Brush.Border}"
                  Background="{DynamicResource ArcChat.Brush.Surface}">
            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <TextBlock Text="{Binding ConversationTopic}"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Role}"
                           Opacity="0.62" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="Open"
                      Command="{Binding #SearchChatRoot.DataContext.OpenCommand}"
                      CommandParameter="{Binding}" />
              <TextBlock Grid.Row="1"
                         Grid.ColumnSpan="2"
                         Margin="0,6,0,0"
                         Text="{Binding Snippet}"
                         TextWrapping="Wrap"
                         Opacity="0.76" />
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
