<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conversations="using:ArcChat.Desktop.Features.Conversations"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="ArcChat.Desktop.Features.Conversations.ExporterView"
             x:DataType="conversations:ExporterViewModel"
             d:DesignWidth="760"
             d:DesignHeight="420"
             mc:Ignorable="d">
  <Design.DataContext>
    <conversations:ExporterViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*"
        ColumnDefinitions="2*,3*"
        ColumnSpacing="16"
        RowSpacing="10">
    <DockPanel Grid.Row="0"
               Grid.ColumnSpan="2"
               LastChildFill="True">
      <StackPanel DockPanel.Dock="Right"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Content="Refresh"
                Command="{Binding RefreshCommand}" />
        <Button Content="Share"
                Command="{Binding ShareCommand}" />
        <Button Content="Capture"
                Command="{Binding CaptureImageCommand}"
                CommandParameter="{Binding #ExportCaptureRoot}" />
      </StackPanel>
      <StackPanel Orientation="Horizontal"
                  Spacing="8">
        <Button Content="Markdown"
                Command="{Binding SelectMarkdownCommand}" />
        <Button Content="JSON"
                Command="{Binding SelectJsonCommand}" />
        <Button Content="Image"
                Command="{Binding SelectImageCommand}" />
      </StackPanel>
    </DockPanel>

    <conversations:MessageSelectorView Grid.Row="1"
                                       Grid.Column="0"
                                       DataContext="{Binding Selector}" />

    <Grid Grid.Row="1"
          Grid.Column="1"
          RowDefinitions="*,Auto"
          RowSpacing="8">
      <Border x:Name="ExportCaptureRoot"
              BorderBrush="{DynamicResource ArcChat.Brush.Border}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12"
              Background="{DynamicResource ArcChat.Brush.Surface}">
        <ScrollViewer>
          <SelectableTextBlock Text="{Binding PreviewText}"
                               TextWrapping="Wrap" />
        </ScrollViewer>
      </Border>
      <TextBlock Grid.Row="1"
                 Text="{Binding StatusMessage}"
                 Opacity="0.7" />
    </Grid>
  </Grid>
</UserControl>
