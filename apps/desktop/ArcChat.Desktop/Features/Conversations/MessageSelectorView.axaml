<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conversations="using:ArcChat.Desktop.Features.Conversations"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="ArcChat.Desktop.Features.Conversations.MessageSelectorView"
             x:DataType="conversations:MessageSelectorViewModel"
             d:DesignWidth="520"
             d:DesignHeight="360"
             mc:Ignorable="d">
  <Design.DataContext>
    <conversations:MessageSelectorViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,*"
        RowSpacing="8">
    <DockPanel Grid.Row="0"
               LastChildFill="True">
      <StackPanel DockPanel.Dock="Right"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Content="Select all"
                Command="{Binding SelectAllCommand}" />
        <Button Content="Invert"
                Command="{Binding InvertCommand}" />
      </StackPanel>
      <TextBlock Text="Messages"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center" />
    </DockPanel>

    <TextBox Grid.Row="1"
             PlaceholderText="Search selected chat"
             Text="{Binding SearchText, Mode=TwoWay}" />

    <ListBox Grid.Row="2"
             ItemsSource="{Binding VisibleItems}"
             Background="Transparent"
             BorderThickness="0">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <VirtualizingStackPanel />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate DataType="conversations:MessageSelectorItem"
                      x:DataType="conversations:MessageSelectorItem">
          <Grid ColumnDefinitions="Auto,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="8"
                Margin="0,0,0,8">
            <CheckBox Grid.RowSpan="2"
                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                      VerticalAlignment="Top" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
              <TextBlock Text="{Binding RoleName}"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding Date}"
                         FontSize="12"
                         Opacity="0.62" />
            </StackPanel>
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Text="{Binding Preview}"
                       TextWrapping="Wrap"
                       Opacity="0.76" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
