<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="using:Avalonia.Automation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:masks="using:ArcChat.Desktop.Features.Masks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="ArcChat.Desktop.Features.Masks.NewChatView"
             x:Name="NewChatRoot"
             x:DataType="masks:NewChatViewModel"
             d:DesignWidth="860"
             d:DesignHeight="620"
             mc:Ignorable="d">
  <Design.DataContext>
    <masks:NewChatViewModel />
  </Design.DataContext>

  <Grid Margin="24,0,24,24"
        RowDefinitions="Auto,Auto,*"
        RowSpacing="18"
        Background="{DynamicResource ArcChat.Brush.Surface}">
    <DockPanel Grid.Row="0"
               LastChildFill="True">
      <StackPanel DockPanel.Dock="Right"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Content="Return"
                Command="{Binding ReturnHomeCommand}"
                automation:AutomationProperties.Name="Return home" />
        <Button Content="Find More"
                Command="{Binding MoreMasksCommand}"
                automation:AutomationProperties.Name="Find more masks" />
      </StackPanel>
      <StackPanel Spacing="4">
        <TextBlock Text="Pick a Mask"
                   FontSize="{DynamicResource ArcChat.FontSize.Title}"
                   FontWeight="SemiBold" />
        <TextBlock Text="Chat with the Soul behind the Mask"
                   Opacity="0.68" />
      </StackPanel>
    </DockPanel>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*,Auto"
          ColumnSpacing="12">
      <StackPanel Spacing="6">
        <TextBlock Text="Provider"
                   FontWeight="SemiBold"
                   Opacity="0.76" />
        <ComboBox ItemsSource="{Binding Providers}"
                  SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                  automation:AutomationProperties.Name="Provider">
          <ComboBox.ItemTemplate>
            <DataTemplate DataType="masks:ProviderOption"
                          x:DataType="masks:ProviderOption">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Spacing="6">
        <TextBlock Text="Model"
                   FontWeight="SemiBold"
                   Opacity="0.76" />
        <ComboBox ItemsSource="{Binding Models}"
                  SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                  automation:AutomationProperties.Name="Model">
          <ComboBox.ItemTemplate>
            <DataTemplate DataType="masks:ModelOption"
                          x:DataType="masks:ModelOption">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <Button Grid.Column="2"
              MinWidth="128"
              Margin="0,24,0,0"
              Content="Just Start"
              Command="{Binding StartBlankCommand}"
              automation:AutomationProperties.Name="Start blank chat" />
    </Grid>

    <Grid Grid.Row="2"
          RowDefinitions="Auto,*"
          RowSpacing="10">
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding StatusMessage}"
                   Opacity="0.7"
                   VerticalAlignment="Center" />
        <TextBlock Text="Recommended masks"
                   FontWeight="SemiBold"
                   Opacity="0.82" />
      </DockPanel>

      <ListBox Grid.Row="1"
               ItemsSource="{Binding RecommendedMasks}"
               Background="Transparent"
               BorderThickness="0"
               automation:AutomationProperties.Name="Recommended masks">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="masks:RecommendedMaskItem"
                        x:DataType="masks:RecommendedMaskItem">
            <Border Margin="0,0,0,8"
                    Padding="12"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ArcChat.Brush.Border}"
                    Background="{DynamicResource ArcChat.Brush.Surface}">
              <Grid ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="12">
                <Border Width="42"
                        Height="42"
                        CornerRadius="8"
                        Background="{DynamicResource ArcChat.Brush.SurfaceAlt}">
                  <TextBlock Text="{Binding Avatar}"
                             FontSize="20"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1"
                            Spacing="4">
                  <StackPanel Orientation="Horizontal"
                              Spacing="8">
                    <TextBlock Text="{Binding Name}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Model}"
                               Opacity="0.62" />
                  </StackPanel>
                  <TextBlock Text="{Binding Summary}"
                             TextWrapping="Wrap"
                             MaxLines="2"
                             Opacity="0.72" />
                </StackPanel>
                <Button Grid.Column="2"
                        Content="Start"
                        Command="{Binding #NewChatRoot.DataContext.StartWithMaskCommand}"
                        CommandParameter="{Binding}"
                        automation:AutomationProperties.Name="Start chat with mask" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
  </Grid>
</UserControl>
