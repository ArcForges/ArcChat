<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:ArcChat.UI.Controls"
             xmlns:nav="using:ArcChat.Desktop.Navigation"
             xmlns:vm="using:ArcChat.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="ArcChat.Desktop.Views.TwoPaneScaffold"
             x:DataType="vm:MainWindowViewModel"
             d:DesignWidth="1080"
             d:DesignHeight="720"
             mc:Ignorable="d">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <controls:ResizableSplitPane x:Name="ShellSplitPane"
                               PaneLength="{Binding SidebarPaneLength, Mode=TwoWay}"
                               MinPaneLength="100"
                               MaxPaneLength="360">
    <controls:ResizableSplitPane.Left>
      <controls:Sidebar x:Name="ShellSidebar"
                        Items="{Binding NavigationItems}"
                        SelectedId="{Binding CurrentDestination.Id}"
                        IsNarrow="{Binding IsSidebarNarrow}"
                        NavigateCommand="{Binding NavigateCommand}" />
    </controls:ResizableSplitPane.Left>

    <controls:ResizableSplitPane.Right>
      <Grid RowDefinitions="Auto,*"
            Background="{DynamicResource ArcChat.Brush.WindowBackground}">
        <DockPanel Grid.Row="0"
                   LastChildFill="True"
                   Margin="24,20,24,12">
          <StackPanel DockPanel.Dock="Right"
                      Orientation="Horizontal"
                      Spacing="8">
            <controls:IconButton Text="Back"
                                 Icon="&lt;"
                                 Command="{Binding BackCommand}" />
            <controls:IconButton Text="Forward"
                                 Icon="&gt;"
                                 Command="{Binding ForwardCommand}" />
          </StackPanel>
          <TextBlock x:Name="HeaderText"
                     Text="ArcChat"
                     FontSize="{DynamicResource ArcChat.FontSize.Title}"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </DockPanel>

        <ContentControl x:Name="ShellContent"
                        Grid.Row="1"
                        Content="{Binding CurrentDestination}">
          <ContentControl.ContentTemplate>
            <DataTemplate x:DataType="nav:Destination">
              <Grid Margin="24,0,24,24"
                    Background="{DynamicResource ArcChat.Brush.Surface}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                  <TextBlock x:Name="DestinationTitle"
                             Text="{Binding Title}"
                             FontSize="28"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding Id}"
                             Foreground="{DynamicResource ArcChat.Brush.MutedText}"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ContentControl.ContentTemplate>
        </ContentControl>
      </Grid>
    </controls:ResizableSplitPane.Right>
  </controls:ResizableSplitPane>
</UserControl>
