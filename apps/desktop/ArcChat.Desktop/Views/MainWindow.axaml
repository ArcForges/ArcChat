<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ArcChat.Desktop.ViewModels"
        xmlns:shell="using:ArcChat.Desktop.Features.Shell"
        xmlns:views="using:ArcChat.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="ArcChat.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ArcChat"
        Width="1080"
        Height="720"
        MinWidth="800"
        MinHeight="600"
        Background="{DynamicResource ArcChat.Brush.WindowBackground}"
        d:DesignWidth="1080"
        d:DesignHeight="720"
        mc:Ignorable="d">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+K"
                Command="{Binding CommandPalette.OpenCommand}" />
  </Window.KeyBindings>

  <Grid KeyboardNavigation.TabNavigation="Cycle">
    <views:TwoPaneScaffold />
    <shell:CommandPaletteView DataContext="{Binding CommandPalette}" />
  </Grid>
</Window>
