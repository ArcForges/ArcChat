<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:theme="using:ArcChat.UI.Theme"
             x:Class="ArcChat.Desktop.App"
             RequestedThemeVariant="Default">
  <Application.Styles>
    <theme:ArcChatTheme ColorScheme="System" />
  </Application.Styles>
</Application>
